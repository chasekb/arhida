# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_DB=your_database
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_PORT=5432

# For Docker environment
DOCKER_POSTGRES_HOST=db-postgres
DOCKER_POSTGRES_USER_FILE=db/postgres-u.txt
DOCKER_POSTGRES_PASSWORD_FILE=db/postgres-p.txt

# Schema and Table Configuration
POSTGRES_SCHEMA=your_schema
POSTGRES_TABLE=arxiv

# Vector Database Configuration
VECTOR_DB_PROVIDER=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=arxiv_metadata
VECTOR_SIZE=384

# Embeddings Service Configuration
EMBEDDING_SERVICE_URL=http://embeddings:8000
EMBEDDING_MODEL_NAME=bge-small-en-v1.5
EMBEDDING_REQUEST_TIMEOUT_MS=30000
EMBEDDING_MAX_BATCH_SIZE=64
EMBEDDING_RETRY_COUNT=3

# Embeddings Runtime / Model Artifacts
MODEL_PATH=/models/bge-small-en-v1.5/model.onnx
TOKENIZER_PATH=/models/bge-small-en-v1.5/tokenizer
DEVICE=cpu
ORT_EXECUTION_PROVIDER=CPU
CUDA_VISIBLE_DEVICES=0
ACCELERATOR_BACKEND=onnx
SERVICE_PORT=8000

# Rate Limiting Configuration
ARXIV_RATE_LIMIT_DELAY=3
ARXIV_BATCH_SIZE=2000
ARXIV_MAX_RETRIES=3
ARXIV_RETRY_AFTER=5

# Backfill Configuration
BACKFILL_CHUNK_SIZE=7
BACKFILL_START_DATE=2007-01-01
